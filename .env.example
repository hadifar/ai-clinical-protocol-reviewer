# Copy to .env and adjust. All values are optional; defaults live in src/core/config.py.

# --- Embeddings (FastEmbed) ---
# EMBED_MODEL=BAAI/bge-large-en-v1.5
# EMBED_DIMENSION=1024
# SPARSE_MODEL=Qdrant/bm25
# MAX_TOKENS=6000

# --- LLM backend (Ollama) ---
# The model must support tool calling + structured output for the IE agent.
# Pull it first, e.g.: `ollama pull qwen2.5`
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_NUM_CTX=8192
# OLLAMA_SEED=42

# --- Vector store (Qdrant, local file-based) ---
# QDRANT_COLLECTION=clinical_chunks

# --- Retrieval / agent ---
# APPLY_RERANKING=false
# APPLY_QUERY_EXPANSION=true
# AGENT_SEARCH_K=5
